<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_banner_dz">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <include layout="@layout/logo_header" />

        <TextView
            android:id="@+id/tvAdminMenuTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage menu"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvAdminMenuInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Here you can manage items in the menu."
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackAdminMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"
            app:cornerRadius="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to orders"
            android:textAllCaps="false"
            android:layout_marginTop="12dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"
            app:cornerRadius="22dp" />

    </LinearLayout>

</ScrollView>
