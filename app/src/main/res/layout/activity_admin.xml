<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_banner_dz">

    <LinearLayout
        android:id="@+id/layoutAdminRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <include layout="@layout/logo_header" />

        <TextView
            android:id="@+id/tvAdminTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin panel"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage menu"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"
            app:cornerRadius="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage orders"
            android:textAllCaps="false"
            android:layout_marginTop="12dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"
            app:cornerRadius="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View feedback"
            android:textAllCaps="false"
            android:layout_marginTop="12dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"
            app:cornerRadius="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogoutAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign out"
            android:textAllCaps="false"
            android:textColor="#4A3F35"
            android:backgroundTint="@android:color/white"
            app:cornerRadius="22dp"
            android:layout_marginTop="24dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
