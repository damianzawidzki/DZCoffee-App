<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_banner_dz">

    <ImageView
        android:id="@+id/imgLogoAdmin"
        android:layout_width="140dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_dz_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvAdminTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin panel"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/imgLogoAdmin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvAdminTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage menu"
            android:textAllCaps="false"
            android:textColor="#4A3F35"
            android:backgroundTint="@android:color/white"
            app:cornerRadius="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage orders"
            android:textAllCaps="false"
            android:textColor="#4A3F35"
            android:backgroundTint="@android:color/white"
            app:cornerRadius="22dp"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Feedback"
            android:textAllCaps="false"
            android:textColor="#4A3F35"
            android:backgroundTint="@android:color/white"
            app:cornerRadius="22dp"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogoutAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign out"
            android:textAllCaps="false"
            android:textColor="#4A3F35"
            android:backgroundTint="@android:color/white"
            app:cornerRadius="22dp"
            android:layout_marginTop="24dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
