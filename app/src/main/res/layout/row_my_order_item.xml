<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5E0C8"
    android:padding="10dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvStatusMy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pending"
            android:textStyle="bold"
            android:textColor="#4E342E"/>

        <TextView
            android:id="@+id/tvCreatedAtMy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="11 NOV 2025, 10:30"
            android:textColor="#6D4C41"
            android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTotalMy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="£0.00"
        android:textStyle="bold"
        android:textColor="#4E342E"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailsMy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Details"
            android:textAllCaps="false"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFeedbackMy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Feedback"
            android:textAllCaps="false"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelMy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"/>
    </LinearLayout>

</LinearLayout>
