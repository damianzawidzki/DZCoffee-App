<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_banner_dz">

    <ImageView
        android:id="@+id/imgLogoReg"
        android:layout_width="140dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_dz_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tvRegTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create customer account"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imgLogoReg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvRegTitle"
        app:layout_constraintBottom_toTopOf="@id/llBackToLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/edtFirstName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="First name"
                android:inputType="textPersonName"
                android:padding="10dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/edtLastName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="Last name"
                android:inputType="textPersonName"
                android:padding="10dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/edtDob"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="Date of birth (dd.MM.yyyy)"
                android:inputType="text"
                android:padding="10dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:padding="10dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/edtLoginName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="Login (username)"
                android:inputType="text"
                android:padding="10dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/edtPasswordReg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="Password"
                android:inputType="textPassword"
                android:padding="10dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/edtConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="Confirm password"
                android:inputType="textPassword"
                android:padding="10dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@android:color/black"
                android:textColorHint="#888888"
                android:layout_marginTop="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegisterCustomer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Register"
                android:textAllCaps="false"
                android:textColor="#4A3F35"
                android:backgroundTint="#FFFFFF"
                app:cornerRadius="22dp"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/llBackToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tvAlready"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account?"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/tvGoLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  Go back to login"
            android:textColor="@android:color/white"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
