<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_banner_dz">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="140dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_dz_logo"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/tvRegisterAdminTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Register admin"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/edtAdminFirstName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="First name"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/edtAdminLastName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Last name"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/edtAdminUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Admin username (login)"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/edtAdminEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Admin email"
            android:background="@android:color/white"
            android:padding="10dp"
            android:inputType="textEmailAddress"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/edtAdminPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Phone (optional)"
            android:background="@android:color/white"
            android:padding="10dp"
            android:inputType="phone"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/edtAdminNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Note (optional)"
            android:background="@android:color/white"
            android:padding="10dp"
            android:layout_marginTop="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save admin"
            android:textAllCaps="false"
            android:layout_marginTop="16dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackRegisterAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textAllCaps="false"
            android:layout_marginTop="8dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35" />

    </LinearLayout>
</ScrollView>
