<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:padding="8dp">

    <ImageView
        android:id="@+id/imgItem"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:src="@drawable/coffee_latte" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Product name"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/imgItem"
        app:layout_constraintTop_toTopOf="@id/imgItem"
        app:layout_constraintEnd_toStartOf="@id/btnRemove" />

    <TextView
        android:id="@+id/tvOptions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Small • Oat milk • Sugar: 1"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@id/tvName"
        app:layout_constraintTop_toBottomOf="@id/tvName"
        app:layout_constraintEnd_toStartOf="@id/btnRemove" />

    <TextView
        android:id="@+id/tvQtyPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="x1  •  £3.20"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@id/tvName"
        app:layout_constraintTop_toBottomOf="@id/tvOptions"
        app:layout_constraintBottom_toBottomOf="@id/imgItem"
        app:layout_constraintEnd_toStartOf="@id/btnRemove" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRemove"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:text="X"
        android:textAllCaps="false"
        android:textSize="10sp"
        android:textColor="#4A3F35"
        android:backgroundTint="#FFFFFF"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toTopOf="@id/imgItem"
        app:layout_constraintBottom_toBottomOf="@id/imgItem"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

