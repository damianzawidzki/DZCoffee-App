<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_banner_dz">

    <LinearLayout
        android:id="@+id/layoutSuperAdminRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgLogoSuperAdmin"
            android:layout_width="140dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_dz_logo"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSuperAdminTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Super admin"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- BUTTON 1: MANAGE ADMIN PANEL -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageAdminPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage admin panel"
            android:textAllCaps="false"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"
            app:cornerRadius="22dp" />

        <!-- BUTTON 2: REGISTER ADMIN -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegisterAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Register admin"
            android:textAllCaps="false"
            android:layout_marginTop="12dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"
            app:cornerRadius="22dp" />

        <!-- small logout button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogoutSuperAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign out"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"
            android:backgroundTint="@android:color/white"
            android:textColor="#4A3F35"
            app:cornerRadius="22dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
